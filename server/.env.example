# ── MySQL 数据库 ──────────────────────────────────
MYSQL_HOST=127.0.0.1        # 数据库地址
MYSQL_PORT=3306              # 数据库端口
MYSQL_USER=root              # 数据库用户名
MYSQL_PASSWORD=your_password # 数据库密码
MYSQL_DATABASE=astron_claw   # 数据库名称

# ── Redis 缓存 & 消息路由 ────────────────────────────
REDIS_HOST=127.0.0.1        # Redis 地址
REDIS_PORT=6379              # Redis 端口
REDIS_PASSWORD=your_password # Redis 密码
REDIS_DB=0                   # Redis DB 编号（集群模式下忽略）
REDIS_CLUSTER=false          # 是否启用 Redis 集群模式

# ── 服务端 ───────────────────────────────────────
SERVER_HOST=0.0.0.0          # 监听地址
SERVER_PORT=8765             # 监听端口
# SERVER_WORKERS=            # Worker 进程数（默认: CPU 核数 + 1）
SERVER_LOG_LEVEL=info        # 日志级别（debug / info / warning / error）
SERVER_ACCESS_LOG=true       # 是否启用 HTTP 访问日志
# LOG_DIR=logs               # 日志文件目录（默认: server/logs）
# LOG_FORMAT_JSON=false      # 是否输出 JSON 格式日志（用于 ELK/Loki 等日志聚合系统）

# ── 消息队列（可选，一般无需修改）─────────────────────
# QUEUE_TYPE=redis_stream    # 队列类型
# QUEUE_MAX_STREAM_LEN=1000  # Redis Stream 最大长度
# QUEUE_BLOCK_MS=5000        # 消费阻塞等待时间（毫秒）

# ── 对象存储（媒体文件）──────────────────────────────
# OSS_TYPE 可选: s3 (Amazon S3 / MinIO), ifly_gateway (讯飞网关存储)
OSS_TYPE=s3
OSS_ENDPOINT=http://localhost:9000   # 存储服务地址
OSS_ACCESS_KEY=minioadmin            # 访问密钥
OSS_SECRET_KEY=your_password         # 私有密钥
OSS_BUCKET=astron-claw-media         # 存储桶名称
OSS_PUBLIC_ENDPOINT=http://localhost:9000  # 公网下载地址（S3 专用，默认同 OSS_ENDPOINT）
# OSS_REGION=us-east-1               # S3 区域（S3 专用）
# OSS_TTL=157788000                  # 下载链接有效期，秒（讯飞网关专用，默认约 5 年）

# ── OTLP 遥测（可选）─────────────────────────────────
OTLP_ENABLED=false                   # 是否启用遥测指标
# OTLP_SERVICE_NAME=astron-claw      # 服务标识
# OTLP_EXPORT_INTERVAL_MS=10000      # 指标刷新到 Redis 的周期（毫秒）

# ── CORS 跨域（前后端分离必需）──────────────────────────
CORS_ENABLED=true                    # 是否启用 CORS 中间件
CORS_ORIGINS=*                       # 允许的来源（逗号分隔），生产环境建议设为前端域名如 http://localhost:5173

# ── 前端服务 ──────────────────────────────────────────
SERVE_FRONTEND=true                  # 是否由后端提供前端 HTML（前后端分离部署时设为 false）
