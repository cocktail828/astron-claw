MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=astron_claw

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_password
REDIS_DB=0
REDIS_CLUSTER=false

SERVER_HOST=0.0.0.0
SERVER_PORT=8765
# SERVER_WORKERS=  # default: cpu_count + 1
SERVER_LOG_LEVEL=info
SERVER_ACCESS_LOG=true

# QUEUE_TYPE=redis_stream
# QUEUE_MAX_STREAM_LEN=1000
# QUEUE_BLOCK_MS=5000

# ── Object Storage ────────────────────────────────
# OSS_TYPE options: s3 (Amazon S3 / MinIO), ifly_gateway (iFlytek Gateway Storage)
OSS_TYPE=s3
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=your_password
OSS_BUCKET=astron-claw-media
# S3 only: public download endpoint (defaults to OSS_ENDPOINT if not set)
OSS_PUBLIC_ENDPOINT=http://localhost:9000
# OSS_REGION=us-east-1
# iFlytek Gateway only: download link TTL in seconds (default ~5 years)
# OSS_TTL=157788000
